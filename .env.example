# Copy to `.env` and edit. Used by both `npm run dev` (local) and docker
# compose (homelab). Compose only reads SECRET_KEY + ALLOWED_ORIGINS +
# BOOT_* from this file — the rest are hardcoded in docker-compose.yml.

# ============================================================================
# REQUIRED
# ============================================================================

# JWT signing key. Generate a real one — changing it invalidates every
# issued login token.
#   openssl rand -hex 48
SECRET_KEY=change-me-to-a-long-random-string

# Local SQLite path. Dev only — in compose the container writes to /data
# (bind-mounted from ./data).
DATABASE_URL=./data/shirabe.db

# ============================================================================
# DEV-ONLY (ignored by compose)
# ============================================================================

PORT=3000
NAVIDROME_URL=http://localhost:4533
PUBLIC_FRONTEND_ORIGIN=http://localhost:5173
BEETS_BIN=beet
BEETS_CONFIG=/etc/beets/config.yaml
DOWNLOADS_DIR=./downloads
MUSIC_DIR=./music

# ============================================================================
# OPTIONAL — CORS
# ============================================================================

# Comma-separated origins beyond the default. Set when fronting Shirabe with
# a reverse proxy on a different hostname (e.g. https://shirabe.example.com).
ALLOWED_ORIGINS=

# ============================================================================
# OPTIONAL — DISCORD BOT
# ============================================================================
#
# Only required if you spin up the `discord-bot` service in
# docker-compose.yml. Create a Discord application at
# https://discord.com/developers/applications, then:
#   - General Information → copy Application ID into DISCORD_APP_ID
#   - Bot → Reset Token → copy into DISCORD_BOT_TOKEN
#   - Installation → tick "User Install" + "Guild Install",
#                    scope `applications.commands`
# After first `docker compose up -d` for the bot, publish the slash
# command once with:
#   docker compose run --rm discord-bot npm run register

# DISCORD_APP_ID=
# DISCORD_BOT_TOKEN=

# Optional brand-logo emojis on the /nowplaying buttons. Generated by:
#   1. Drop PNGs into discord-bot/emojis/ (e.g. spotify.png, youtube_music.png,
#      lastfm.png, shirabe.png — filename becomes the emoji name)
#   2. docker compose run --rm discord-bot npm run upload-emojis
#   3. Paste the printed EMOJI_* lines below.
# Buttons gracefully fall back to label-only if these aren't set.
# EMOJI_SPOTIFY=
# EMOJI_YTM=
# EMOJI_LASTFM=
# EMOJI_SHIRABE=

# The desktop Rich Presence client (./discord-rpc) reads its own
# .env from that directory — it does NOT use this file.

# ============================================================================
# OPTIONAL — FIRST-RUN SEEDING
# ============================================================================
#
# Any BOOT_* variable below is copied into the settings table the FIRST time
# the server starts against an empty settings table. After that, change
# values in the Settings UI — these are ignored on subsequent boots.
#
# Saves you from clicking through Settings on a fresh deploy. Comment back
# out anything you'd rather configure via the UI.

# BOOT_LASTFM_API_KEY=
# BOOT_LASTFM_SHARED_SECRET=
# BOOT_LASTFM_USERNAME=
# BOOT_LISTENBRAINZ_USERNAME=
# BOOT_LISTENBRAINZ_TOKEN=
# BOOT_SLSKD_URL=http://slskd:5030
# BOOT_SLSKD_API_KEY=
# BOOT_NAVIDROME_URL=http://navidrome:4533
# BOOT_NAVIDROME_USERNAME=
# BOOT_NAVIDROME_PASSWORD=
# BOOT_RELAY_LASTFM=true
# BOOT_RELAY_LISTENBRAINZ=true
# BOOT_SUGGESTION_SCHEDULE=0 */6 * * *
# BOOT_DISMISS_COOLDOWN_DAYS=30
