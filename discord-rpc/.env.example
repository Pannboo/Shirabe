# Copy to .env and fill in.

# Discord application ID from https://discord.com/developers/applications
DISCORD_APP_ID=

# Public URL of your Shirabe instance (RPC needs to reach it from your
# desktop). Tailscale / Cloudflare Tunnel / plain DNS — whatever works.
SHIRABE_PUBLIC_URL=https://shirabe.yourdomain.com

# How often to re-poll. 10s is a sensible default.
POLL_SECONDS=10
